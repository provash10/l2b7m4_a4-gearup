model User {
  id           String       @id @default(uuid())
  name         String       @db.VarChar(255)
  email        String       @unique
  password     String
  profilePhoto String?
  activeStatus ActiveStatus @default(ACTIVE)
  role         Role         @default(CUSTOMER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

   gearItems    GearItem[]
   reviews      Review[]
   rentalOrders RentalOrder[]

  @@map("users")
}
