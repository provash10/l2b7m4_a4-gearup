model Payment {
  id            String        @id @default(uuid())
  transactionId String        @unique
  rentalOrderId String
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}
