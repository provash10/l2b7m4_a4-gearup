model GearItem {
  id           String      @id @default(uuid())
  name         String
  description  String
  pricePerDay  Float
  brand        String
  stock        Int         @default(1)
  isAvailable  Boolean     @default(true)
  categoryId   String
  providerId   String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("gear_items")
}
